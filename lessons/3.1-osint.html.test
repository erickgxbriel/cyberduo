        let currentStep = 0;
        let selectedIdx = null; // For quiz and fill
        let hearts = 5;
        let shuffledOptions = [];
        
        // Match state
        let matchLeft = [];
        let matchRight = [];
        let selectedLeft = null;
        let selectedRight = null;
        let matchesFound = 0;

        function shuffle(array) {
            let currentIndex = array.length, randomIndex;
            while (currentIndex != 0) {
                randomIndex = Math.floor(Math.random() * currentIndex);
                currentIndex--;
                [array[currentIndex], array[randomIndex]] = [array[randomIndex], array[currentIndex]];
            }
            return array;
        }

        function updateProgress() {
            const progress = (currentStep / steps.length) * 100;
            document.getElementById('progressFill').style.width = `${progress}%`;
            
            const container = document.getElementById('heartsContainer');
            container.innerHTML = Array(5).fill(0).map((_, i) => `<i class="${i < hearts ? 'fas' : 'far'} fa-heart"></i>`).join('');
        }

        function render() {
            if (currentStep >= steps.length) { showVictory(); return; }
            const step = steps[currentStep];
            const area = document.getElementById('gameArea');
            const checkBtn = document.getElementById('checkBtn');
            
            updateProgress();
            
            // Reset states
            selectedIdx = null;
            checkBtn.disabled = true;
            checkBtn.classList.remove('active');
            checkBtn.innerText = (step.type === 'teach' || step.type === 'example') ? 'Continuar' : 'Verificar';
            
            if (step.type === 'teach' || step.type === 'example') {
                checkBtn.disabled = false;
                checkBtn.classList.add('active');
            }

            area.innerHTML = '';

            if (step.type === 'teach') {
                area.innerHTML = `
                    <div class="game-card teach-card">
                        <div class="module-subtitle"><i class="fas ${step.icon}"></i> NOVO CONCEITO</div>
                        <h2 class="title-main">${step.title}</h2>
                        <div class="text-body">${step.content}</div>
                        ${step.highlight ? `<div class="teach-highlight"><i class="fas fa-lightbulb mr-2"></i>${step.highlight}</div>` : ''}
                    </div>
                `;
            } 
            else if (step.type === 'example') {
                area.innerHTML = `
                    <div class="game-card example-card">
                        <div class="module-subtitle"><i class="fas ${step.icon}"></i> NA PRÁTICA</div>
                        <h2 class="title-main">${step.title}</h2>
                        <div class="example-scenario text-body">${step.scenario}</div>
                        ${step.code ? `<div class="example-code">${step.code}</div>` : ''}
                        <div class="example-takeaway"><i class="fas fa-arrow-right mt-1" style="color: var(--cyber-blue)"></i> ${step.takeaway}</div>
                    </div>
                `;
            }
            else if (step.type === 'quiz') {
                shuffledOptions = shuffle([...step.options]);
                area.innerHTML = `
                    <div class="game-card">
                        <div class="quiz-title">${step.task}</div>
                        <div class="options-grid">
                            ${shuffledOptions.map((opt, i) => `
                                <div class="option-card" onclick="selectQuiz(${i})" id="opt-${i}">
                                    <div class="option-number">${i+1}</div>
                                    <span>${opt}</span>
                                </div>
                            `).join('')}
                        </div>
                    </div>
                `;
            }
            else if (step.type === 'fill') {
                shuffledOptions = shuffle([...step.options]);
                const sentenceParts = step.sentence.split('___');
                
                area.innerHTML = `
                    <div class="game-card">
                        <div class="module-subtitle"><i class="fas fa-pen-to-square"></i> COMPLETE A FRASE</div>
                        <div class="fill-sentence">
                            ${sentenceParts[0]}<span class="fill-slot" id="fillSlot"></span>${sentenceParts[1]}
                        </div>
                        <div class="options-grid">
                            ${shuffledOptions.map((opt, i) => `
                                <div class="option-card" style="justify-content: center;" onclick="selectFill(${i})" id="opt-${i}">
                                    <span>${opt}</span>
                                </div>
                            `).join('')}
                        </div>
                    </div>
                `;
            }
            else if (step.type === 'match') {
                matchesFound = 0;
                matchLeft = shuffle(step.pairs.map((p, i) => ({text: p.term, id: i})));
                
                let isDeranged = false;
                while (!isDeranged) {
                    matchRight = shuffle(step.pairs.map((p, i) => ({text: p.definition, id: i})));
                    isDeranged = true;
                    for (let j = 0; j < matchLeft.length; j++) {
                        if (matchLeft[j].id === matchRight[j].id) {
                            if (matchLeft.length > 1) {
                                isDeranged = false;
                                break;
                            }
                        }
                    }
                }
                selectedLeft = null;
                selectedRight = null;
                
                area.innerHTML = `
                    <div class="game-card">
                        <div class="module-subtitle"><i class="fas fa-link"></i> ASSOCIE OS PARES</div>
                        <div class="quiz-title">${step.title}</div>
                        <div class="match-container">
                                ${matchLeft.map((item, i) => `
                                    <div class="match-item" id="left-${i}" onclick="selectMatch('left', ${i}, ${item.id})">${item.text}</div>
                                    <div class="match-item" id="right-${i}" onclick="selectMatch('right', ${i}, ${matchRight[i].id})">${matchRight[i].text}</div>
                                `).join('')}
                        </div>
                    </div>
                `;
            }
            
            area.scrollTop = 0;
        }

        // Interactivity Handlers
        function selectQuiz(idx) {
            selectedIdx = idx;
            document.querySelectorAll('.option-card').forEach((c, i) => c.classList.toggle('selected', i === idx));
            document.getElementById('checkBtn').disabled = false;
            document.getElementById('checkBtn').classList.add('active');
        }

        function selectFill(idx) {
            selectedIdx = idx;
            document.querySelectorAll('.option-card').forEach((c, i) => c.classList.toggle('selected', i === idx));
            const slot = document.getElementById('fillSlot');
            slot.innerText = shuffledOptions[idx];
            slot.classList.add('filled');
            document.getElementById('checkBtn').disabled = false;
            document.getElementById('checkBtn').classList.add('active');
        }

        function selectMatch(side, idx, pairId) {
            const item = document.getElementById(`${side}-${idx}`);
            if (item.classList.contains('matched')) return;

            // Clear previous selection on same side
            document.querySelectorAll(`.match-item[id^='${side}-']`).forEach(el => {
                if(!el.classList.contains('matched')) el.classList.remove('selected');
            });
            
            item.classList.add('selected');

            if (side === 'left') selectedLeft = {el: item, id: pairId};
            else selectedRight = {el: item, id: pairId};

            if (selectedLeft && selectedRight) {
                // Check match
                if (selectedLeft.id === selectedRight.id) {
                    selectedLeft.el.classList.remove('selected');
                    selectedLeft.el.classList.add('matched');
                    selectedRight.el.classList.remove('selected');
                    selectedRight.el.classList.add('matched');
                    matchesFound++;
                    
                    if (matchesFound === steps[currentStep].pairs.length) {
                        document.getElementById('checkBtn').disabled = false;
                        document.getElementById('checkBtn').classList.add('active');
                    }
                } else {
                    let errLeft = selectedLeft;
                    let errRight = selectedRight;
                    selectedLeft = null;
                    selectedRight = null;

                    errLeft.el.classList.remove('selected');
                    errLeft.el.classList.add('error');
                    errRight.el.classList.remove('selected');
                    errRight.el.classList.add('error');
                    
                    // Lose heart for wrong match
                    hearts--;
                    updateProgress();
                    if(hearts <= 0) triggerGameOver();

                    setTimeout(() => {
                        errLeft.el.classList.remove('error');
                        errRight.el.classList.remove('error');
                    }, 500);
                    return;
                }
                selectedLeft = null;
                selectedRight = null;
            }
        }

        // Logic Check
        function checkResponse() {
            const step = steps[currentStep];
            const checkBtn = document.getElementById('checkBtn');
            const popup = document.getElementById('feedbackPopup');
            
            // Non-interactive steps just advance
            if (step.type === 'teach' || step.type === 'example') {
                currentStep++;
                render();
                return;
            }

            let isCorrect = false;

            if (step.type === 'quiz' || step.type === 'fill') {
                isCorrect = shuffledOptions[selectedIdx] === step.correctText;
                
                document.querySelectorAll('.option-card').forEach((c, i) => {
                    if (shuffledOptions[i] === step.correctText) c.classList.add('correct');
                    else if (i === selectedIdx) c.classList.add('wrong');
                    c.classList.add('disabled');
                });
            } else if (step.type === 'match') {
                isCorrect = true; // Button only enables when all matches found
            }

            if (isCorrect) {
                document.getElementById('fbTitle').innerHTML = '<i class="fas fa-check-circle"></i> Excelente!';
                document.getElementById('fbTitle').className = "feedback-title text-green-500";
                document.getElementById('fbMsg').innerText = step.explanation || "Você dominou esse conceito.";
                popup.className = "feedback-overlay show correct";
            } else {
                hearts--;
                updateProgress();
                document.getElementById('fbTitle').innerHTML = '<i class="fas fa-times-circle"></i> Incorreto!';
                document.getElementById('fbTitle').className = "feedback-title text-red-500";
                document.getElementById('fbMsg').innerText = step.explanation || "O correto era: " + step.correctText;
                popup.className = "feedback-overlay show wrong";
                
                if (hearts <= 0) {
                    setTimeout(triggerGameOver, 600);
                }
            }
        }

        function triggerGameOver() {
            alert("VOCÊ FICOU SEM VIDAS. O treinamento será reiniciado."); 
            location.reload();
        }

        function handleContinue() {
            document.getElementById('feedbackPopup').classList.remove('show');
            currentStep++;
            render();
        }

        function showVictory() {
            document.getElementById('progressFill').style.width = `100%`;
            document.getElementById('footerArea').classList.add('hidden');
            
            let nextBtnHtml = `<button class="check-btn active w-full" onclick="window.location.href='../lessons/3.2-reconhecimento.html'" style="background: var(--cyber-green); color: black; border-color: var(--cyber-green); box-shadow: 0 4px 0 #008f20; font-size: 1.1rem; padding: 1.2rem; letter-spacing: 2px;">PRÓXIMA LIÇÃO <i class="fas fa-arrow-right ml-2"></i></button>`;
            if (nextBtnHtml.includes("##NEXT_LESSON_BTN" + "##")) {
                nextBtnHtml = `<button class="check-btn active w-full" onclick="window.location.href='../lessons/1.0-introducao.html'" style="background: var(--cyber-green); color: black; border-color: var(--cyber-green); box-shadow: 0 4px 0 #009e80; font-size: 1.1rem; padding: 1.2rem; letter-spacing: 2px;">PRÓXIMA LIÇÃO <i class="fas fa-arrow-right ml-2"></i></button>`;
            }

            document.getElementById('gameArea').innerHTML = `
                <div class="game-card teach-card" style="align-items: center; text-align: center; border-color: var(--cyber-blue)">
                    <i class="fas fa-medal text-6xl text-yellow-400 mb-4 mt-4"></i>
                    <h2 class="title-main mb-2">Você concluiu esta lição e dominou os conceitos apresentados.</h2>
                    <p class="text-body mb-6">Você completou esta lição com sucesso!</p>
                    <div style="display: flex; flex-direction: column; gap: 1rem; width: 100%; align-items: center; margin-top: 1rem;">
                        ${nextBtnHtml}
                        <div style="display: flex; gap: 1rem; width: 100%; max-width: 400px; margin-top: 0.5rem;">
                            <button class="check-btn" onclick="location.reload()" style="flex: 1; background: #161b22; border: 2px solid #30363d; color: #c9d1d9; box-shadow: 0 4px 0 #0d1117; padding: 0.8rem 0.5rem;">
                                <i class="fas fa-rotate-right mb-1 block text-lg"></i>
                                <span style="font-size: 0.75rem; display: block; margin-top: 4px;">REINICIAR</span>
                            </button>
                            <button class="check-btn" onclick="window.location.href='../modules/modulo-03.html'" style="flex: 1; background: #161b22; border: 2px solid var(--cyber-blue); color: var(--cyber-blue); box-shadow: 0 4px 0 rgba(0,255,255,0.2); padding: 0.8rem 0.5rem;">
                                <i class="fas fa-layer-group mb-1 block text-lg"></i>
                                <span style="font-size: 0.75rem; display: block; margin-top: 4px;">MÓDULOS</span>
                            </button>
                        </div>
                    </div>
                </div>
            `;
        }

        render();
    </script>
</body>
</html>
